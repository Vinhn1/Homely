<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="48dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#2E7D32"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="H"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center" />

        </androidx.cardview.widget.CardView>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Chào mừng tới Homely"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Đăng nhập để tìm trọ ưng ý"
            android:textSize="14sp"
            android:textColor="#757575" />

        <!-- Email / Phone Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_email_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BDBDBD"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_email_phone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Email hoặc Số điện thoại"
                android:inputType="textEmailAddress"
                android:textSize="15sp"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="8dp"
                android:paddingStart="16dp"
                android:background="@null" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BDBDBD"
            app:passwordToggleEnabled="true"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edt_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Mật khẩu"
                android:inputType="textPassword"
                android:textSize="15sp"
                android:drawableStart="@drawable/ic_lock"
                android:drawablePadding="8dp"
                android:paddingStart="16dp"
                android:background="@null" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tv_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:text="Quên mật khẩu?"
            android:textSize="13sp"
            android:textColor="#2E7D32"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Đăng nhập →"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="12dp" />

        <!-- Divider: Or continue with -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Hoặc tiếp tục với"
                android:textSize="13sp"
                android:textColor="#9E9E9E" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

        </LinearLayout>

        <!-- Social Login Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Google Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login_google"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Google"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                app:backgroundTint="@color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_google"
                app:iconTint="@null"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <!-- Facebook Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login_facebook"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Facebook"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                app:backgroundTint="@color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_facebook"
                app:iconTint="@null"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

        </LinearLayout>

        <!-- Register Prompt -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có tài khoản? "
                android:textSize="14sp"
                android:textColor="#757575" />

            <TextView
                android:id="@+id/tv_register"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Đăng ký"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>