<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- LOGO CARD - to hơn, đẹp hơn -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogo"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#00000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"
        android:layout_marginBottom="28dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/logo_card_bg">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_homely_logo"
                android:scaleType="fitCenter"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- TÊN APP -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TìmTrọ"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="-0.02"
        app:layout_constraintTop_toBottomOf="@id/cardLogo"
        app:layout_constraintBottom_toTopOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- TAGLINE -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÌM PHÒNG  ·  KẾT NỐI  ·  AN CƯ"
        android:textSize="10sp"
        android:textColor="#80FFFFFF"
        android:letterSpacing="0.18"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintBottom_toTopOf="@id/pillGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"/>

    <!-- PILL TAGS -->
    <LinearLayout
        android:id="@+id/pillGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintBottom_toTopOf="@id/loaderGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phòng trọ"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:background="@drawable/pill_bg"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chung cư"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:background="@drawable/pill_bg"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhà nguyên căn"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:background="@drawable/pill_bg"/>

    </LinearLayout>

    <!-- LOADER GROUP -->
    <LinearLayout
        android:id="@+id/loaderGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/pillGroup"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp">

        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="80dp"
            android:layout_height="3dp"
            android:progressDrawable="@drawable/progress_bar_drawable"
            android:indeterminate="true"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ĐANG TẢI..."
            android:textSize="9sp"
            android:textColor="#4DFFFFFF"
            android:letterSpacing="0.18"/>

    </LinearLayout>

    <!-- VERSION -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0  ·  Firebase &amp; Android"
        android:textSize="9sp"
        android:textColor="#2EFFFFFF"
        android:letterSpacing="0.08"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>